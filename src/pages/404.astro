---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Blake Fox">
  <div class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center">
      <p class="text-7xl font-bold mb-4" style="color: var(--highlight);">404</p>
      <h1 class="text-2xl font-bold mb-3" style="color: var(--text-primary);">Page Not Found</h1>
      <p class="text-base mb-8 max-w-sm mx-auto" style="color: var(--text-secondary);">
        That page doesn't exist. It may have moved or never existed.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md font-semibold text-white text-sm"
          style="background-color: var(--highlight);"
        >
          Go Home
        </a>
        <a
          href="/projects"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md font-semibold text-sm border"
          style="border-color: var(--accent); color: var(--accent);"
        >
          View Work
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
