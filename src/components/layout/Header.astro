---
import NavLink from './NavLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b-2"
  style="background-color: var(--bg-secondary); border-color: var(--highlight);"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between gap-4" style="height: 5rem;">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0" aria-label="Foxteck — Home">
      <img
        src="/assets/personal/foxteck-logo.png"
        alt="Foxteck Logo"
        style="height: 4.5rem; width: auto;"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-2" aria-label="Main navigation">
      <!-- Company group -->
      <span class="text-xs font-semibold uppercase tracking-widest mr-1" style="color: var(--accent); opacity: 0.7;">Co</span>
      <a href="/services" class="nav-link text-sm font-medium px-2 py-1 rounded transition-colors duration-150" style="color: var(--text-secondary);"
        onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-secondary)'">Services</a>
      <a href="/projects" class="nav-link text-sm font-medium px-2 py-1 rounded transition-colors duration-150" style="color: var(--text-secondary);"
        onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-secondary)'">Work</a>
      <a href="/contact?type=foxteck" class="nav-link text-sm font-medium px-2 py-1 rounded transition-colors duration-150" style="color: var(--text-secondary);"
        onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-secondary)'">Contact</a>

      <!-- Divider -->
      <span class="mx-2 text-base" style="color: var(--border);">|</span>

      <!-- Personal group -->
      <span class="text-xs font-semibold uppercase tracking-widest mr-1" style="color: var(--highlight); opacity: 0.7;">Me</span>
      <a href="/about" class="nav-link text-sm font-medium px-2 py-1 rounded transition-colors duration-150" style="color: var(--text-secondary);"
        onmouseover="this.style.color='var(--highlight)'" onmouseout="this.style.color='var(--text-secondary)'">About</a>
      <a href="/timeline" class="nav-link text-sm font-medium px-2 py-1 rounded transition-colors duration-150" style="color: var(--text-secondary);"
        onmouseover="this.style.color='var(--highlight)'" onmouseout="this.style.color='var(--text-secondary)'">Timeline</a>
      <a href="/resume/Fox_Blake_Resume_2026.pdf" target="_blank" rel="noopener noreferrer" class="nav-link text-sm font-medium px-2 py-1 rounded transition-colors duration-150" style="color: var(--text-secondary);"
        onmouseover="this.style.color='var(--highlight)'" onmouseout="this.style.color='var(--text-secondary)'">Resume</a>
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a
        href="/contact"
        class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-semibold text-white tracking-wide transition-colors duration-150"
        style="background-color: var(--highlight);"
        onmouseover="this.style.backgroundColor='var(--highlight-hover)'"
        onmouseout="this.style.backgroundColor='var(--highlight)'"
      >
        Get in Touch
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md"
        style="color: var(--text-secondary);"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t px-4 py-4 flex flex-col gap-1"
    style="background-color: var(--bg-secondary); border-color: var(--border);"
  >
    <!-- Company section -->
    <p class="text-xs font-semibold uppercase tracking-widest pt-2 pb-1" style="color: var(--accent);">Foxteck</p>
    <a href="/services"           class="text-sm font-medium py-2 px-2 rounded" style="color: var(--text-secondary);">Services</a>
    <a href="/projects"           class="text-sm font-medium py-2 px-2 rounded" style="color: var(--text-secondary);">Work</a>
    <a href="/contact?type=foxteck" class="text-sm font-medium py-2 px-2 rounded" style="color: var(--text-secondary);">Contact</a>

    <!-- Personal section -->
    <p class="text-xs font-semibold uppercase tracking-widest pt-4 pb-1" style="color: var(--highlight);">Blake Fox</p>
    <a href="/about"    class="text-sm font-medium py-2 px-2 rounded" style="color: var(--text-secondary);">About</a>
    <a href="/timeline" class="text-sm font-medium py-2 px-2 rounded" style="color: var(--text-secondary);">Timeline</a>
    <a href="/resume/Fox_Blake_Resume_2026.pdf" target="_blank" rel="noopener noreferrer" class="text-sm font-medium py-2 px-2 rounded" style="color: var(--text-secondary);">Resume</a>

    <a
      href="/contact"
      class="mt-3 w-full text-center px-4 py-3 rounded-md text-sm font-semibold text-white"
      style="background-color: var(--highlight);"
    >
      Get in Touch →
    </a>
  </div>
</header>

<script is:inline>
  var btn  = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-menu');
  var ham  = document.getElementById('hamburger-icon');
  var cls  = document.getElementById('close-icon');

  if (btn && menu) {
    btn.addEventListener('click', function () {
      var open = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!open));
      ham.style.display = open ? ''     : 'none';
      cls.style.display = open ? 'none' : '';
    });
  }
</script>
