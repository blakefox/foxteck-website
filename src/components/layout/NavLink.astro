---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
const isActive = Astro.url.pathname === href || (href !== '/' && Astro.url.pathname.startsWith(href));
---

<a
  href={href}
  class:list={[
    'text-sm font-medium tracking-wide uppercase transition-colors duration-150 py-1',
    isActive
      ? 'border-b-2 border-[#4A9EBF] text-[#4A9EBF]'
      : 'hover:text-[#4A9EBF]',
  ]}
  style={isActive ? '' : 'color: var(--text-secondary);'}
>
  {label}
</a>
