---
const stats = [
  { value: '15+', label: 'Years Engineering' },
  { value: '9',   label: 'Companies & Startups' },
  { value: '4',   label: 'VP / CTO Roles' },
  { value: '∞',   label: 'AI-First Thinking' },
];
---

<div class="border-y" style="background-color: var(--bg-surface); border-color: var(--border);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map((s) => (
        <div class="text-center">
          <div class="text-3xl font-bold tracking-tight" style="color: var(--highlight);">{s.value}</div>
          <div class="text-xs uppercase tracking-widest mt-1" style="color: var(--text-secondary);">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</div>
