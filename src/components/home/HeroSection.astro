---
const heroStatement = `I've spent my career at the edge of what AI can do for people.

From building cognitive systems with IBM Watson, to driving real-time facial tracking and extreme character animation with Faceware, to developing AI that extends a doctor's ability to diagnose and treat at HIA Medical — I've never been interested in AI as a novelty. I'm interested in AI that changes what's possible for the person using it.

That conviction runs through everything I build today.`;
---

<section class="relative overflow-hidden py-16 sm:py-24">
  <!-- Background gradient -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 60% at 80% 50%, rgba(74,158,191,0.06) 0%, transparent 60%), radial-gradient(ellipse 50% 40% at 20% 80%, rgba(192,74,26,0.05) 0%, transparent 60%);"
  ></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Text -->
      <div class="order-2 lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--highlight);">
          VP of Engineering · CTO · AI Specialist | Founder, Foxteck Innovations Inc
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-6" style="color: var(--text-primary);">
          Blake Fox<br />
          <span class="text-3xl sm:text-4xl lg:text-5xl font-semibold" style="color: var(--accent);">/ Foxteck Innovations</span>
        </h1>

        <p class="text-base sm:text-lg leading-relaxed mb-8 max-w-lg" style="color: var(--text-secondary);">
          {heroStatement.split('\n\n')[0]}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="/services"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md font-semibold text-sm text-white transition-colors duration-150"
            style="background-color: var(--highlight);"
            onmouseover="this.style.backgroundColor='var(--highlight-hover)'"
            onmouseout="this.style.backgroundColor='var(--highlight)'"
          >
            Work with Foxteck
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a
            href="/about"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md font-semibold text-sm border transition-colors duration-150"
            style="border-color: var(--accent); color: var(--accent); background: transparent;"
            onmouseover="this.style.background='var(--accent-subtle)'"
            onmouseout="this.style.background='transparent'"
          >
            Hire Blake
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a
            href="/resume/Fox_Blake_Resume_2026.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md font-semibold text-sm border transition-colors duration-150"
            style="border-color: var(--border); color: var(--text-secondary); background: transparent;"
            onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'"
            onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-secondary)'"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            Resume
          </a>
        </div>

        <!-- Speaking callout -->
        <div class="mt-8 flex items-center gap-3 text-sm" style="color: var(--text-secondary);">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          <span>Speaker at </span>
          <a
            href="https://www.youtube.com/watch?v=LN-fbYzCQRk"
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium underline underline-offset-2 transition-colors"
            style="color: var(--accent);"
          >
            ITEXPO 2025 — Revolutionizing AI-Generated Video
          </a>
        </div>
      </div>

      <!-- Headshot -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Decorative rings -->
          <div
            class="absolute -inset-3 rounded-full opacity-20"
            style="background: conic-gradient(from 0deg, var(--highlight), var(--accent), var(--highlight)); filter: blur(12px);"
          ></div>
          <div
            class="relative w-56 h-56 sm:w-72 sm:h-72 rounded-full overflow-hidden border-2"
            style="border-color: var(--highlight);"
          >
            <img
              src="/assets/personal/blake-fox-headshot.png"
              alt="Blake Fox — VP of Engineering, CTO, AI Specialist"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
          <!-- Location badge -->
          <div
            class="absolute -bottom-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full text-xs font-medium flex items-center gap-1.5 whitespace-nowrap border"
            style="background-color: var(--bg-surface); border-color: var(--border); color: var(--text-secondary);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Georgetown, TX
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
