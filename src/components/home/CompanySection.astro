---
const pillars = [
  {
    icon: '🧭',
    title: 'Fractional CTO',
    description: 'Embedded part-time technical leadership — strategy, roadmap, team building, and hands-on execution when it counts.',
  },
  {
    icon: '🤖',
    title: 'AI & Agentic Consulting',
    description: 'LLM integration, MCP server architecture, agentic workflow design, and structured AI adoption programs for engineering teams.',
  },
  {
    icon: '🏗️',
    title: 'Full-Stack Product Builds',
    description: 'End-to-end product development — React frontends, Claude-powered backends, CI/CD pipelines, and Azure deployment.',
  },
];
---

<section class="py-16 border-t" style="border-color: var(--border); background-color: var(--bg-surface);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-2 section-label" style="color: var(--accent);">Foxteck Innovations</p>
        <h2 class="text-2xl sm:text-3xl font-bold" style="color: var(--text-primary);">What Foxteck Builds</h2>
      </div>
      <a
        href="/services"
        class="text-sm font-semibold transition-colors duration-150 whitespace-nowrap"
        style="color: var(--accent);"
        onmouseover="this.style.color='var(--accent-hover)'"
        onmouseout="this.style.color='var(--accent)'"
      >
        See all services →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {pillars.map((p) => (
        <div
          class="rounded-xl border p-5 flex flex-col gap-3"
          style="background-color: var(--bg-primary); border-color: var(--border); border-top: 2px solid var(--accent);"
        >
          <div class="text-2xl">{p.icon}</div>
          <h3 class="text-base font-bold" style="color: var(--text-primary);">{p.title}</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">{p.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href="/contact?type=foxteck"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md font-semibold text-sm border transition-colors duration-150"
        style="border-color: var(--accent); color: var(--accent); background: transparent;"
        onmouseover="this.style.background='var(--accent-subtle)'"
        onmouseout="this.style.background='transparent'"
      >
        Start a Conversation
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

  </div>
</section>
